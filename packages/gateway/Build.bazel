load("@rules_swift//swift:swift.bzl", "swift_library", "swift_test")

swift_library(
    name = "Gateway",
    srcs = glob(
        [
            "Core/Sources/Gateway/**/*.swift",
        ],
        exclude = [
            "Core/Sources/Gateway/swift-java.config",
        ],
    ),
    module_name = "Gateway",
    visibility = ["//visibility:public"],
)

swift_test(
    name = "GatewayTests",
    srcs = glob([
        "Core/Tests/GatewayTests/**/*.swift",
    ]),
    deps = [":Gateway"],
)
