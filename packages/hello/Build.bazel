load("@rules_swift//swift:swift.bzl", "swift_library", "swift_test")

filegroup(
    name = "android_sources",
    srcs = glob(["Sources/Java/**/*.kt"]),
    visibility = ["//visibility:public"],
)

swift_test(
    name = "HelloTests",
    srcs = ["Tests/HelloTests/HelloTests.swift"],
    deps = [":Hello"],
)
